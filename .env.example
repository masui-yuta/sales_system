# ローカル開発（XAMPP）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sales_system
DB_SSL=false

# 本番（TiDB Cloud Starter 等）の例
# DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
# DB_PORT=4000
# DB_USER=xxxxxxxx.root
# DB_PASSWORD=your-tidb-password
# DB_NAME=sales_system
# DB_SSL=true

# 認証（32文字以上のランダム文字列。本番では必ず変更）
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
